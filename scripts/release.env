# 域名和镜像默认值。
SERVER_URL=https://platform.tripai.icu
REDINK_PUBLIC_URL=https://redink.tripai.icu

# 阿里云镜像仓库。
REGISTRY_DOMAIN=crpi-dwpdx29dne1d4tyy.cn-chengdu.personal.cr.aliyuncs.com
REGISTRY_USER=1183989659@qq.com
REGISTRY_PASSWORD=Docker4250
NAMESPACE=visus
IMAGE_NAME=nextdevtpl
CONTAINER_NAME=nextdevtpl-app

# 容器只监听本机，交给 Nginx 或 Tunnel 处理外部入口。
APP_BIND_HOST=127.0.0.1
APP_PORT=3000
DOCKER_NETWORK=
LOCAL_STORAGE_VOLUME=nextdevtpl_storage

# 数据库配置。可直接写 DATABASE_URL，也可只改下面几项。
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/nextdevtpl
DB_HOST=host.docker.internal
DB_NAME=nextdevtpl
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
